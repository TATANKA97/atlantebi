{
  "name": "atlantebi",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "build": "pnpm -r --if-present build",
    "db:purge-demo-schema": "pnpm --filter @atlantebi/db purge:adventureworkslt-plan",
    "db:configure-adventureworks-semantic": "pnpm --filter @atlantebi/db configure:adventureworks-semantic",
    "db:purge-demo-semantic": "pnpm --filter @atlantebi/db purge:adventureworks-semantic",
    "schema:audit:adventureworks": "python services/query-engine/scripts/audit_adventureworkslt.py"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "eslint": "10.4.1",
    "globals": "17.6.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "4.1.8"
  }
}
